{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ziptowebsite",
  "compatibility_date": "2026-06-07",
  "observability": {
    "enabled": true
  },
  "assets": {
  "directory": "Frontend/dist",
  "not_found_handling": "single-page-application"
},
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
